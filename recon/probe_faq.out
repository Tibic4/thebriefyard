    onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://fonts.googleapis.com/css?family=Nunito+Sans:400,700,800&display=swap" as="style"
    onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" as="style"
    onload="this.onload=null;this.rel='stylesheet'">
<noscript>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Nunito+Sans:400,700,800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
</noscript>
<script>
    if (window.innerWidth <= 640) {
        document.querySelector(".native-carbon").remove();
        document
            .querySelector(".native-carbon-mobile")
            .classList.add("native-carbon");
        document
            .querySelector(".native-carbon-mobile")
            .classList.remove("native-carbon-mobile");
    }
</script>
<script src="//m.servedby-buysellads.com/monetization.custom.js" type="text/javascript"></script>
<script>
    (function () {
        if (typeof _bsa !== 'undefined' && _bsa) {
            _bsa.init('custom', 'CESIPKJJ', 'placement:SITENAME', {
                target: '.native-carbon',
                template: `
                <div class="native-container relative border-gray-200 border-2 sm:border-none dark:border-teal-900 bg-white dark:bg-teal-900 rounded sm:p-2 mb-3 transition-colors duration-1000">
                    <a href="##link##" class="native-banner flex sm:flex-col">
                        <div class="flex items-center justify-center p-2 min-w-1/3 sm:min-w-0" style="background: ##backgroundColor##">
                          <img class="native-img max-h-10" src="##logo##" style="background: ##backgroundColor##">
                        </div>
                        <span>
                            <div class="native-details flex flex-col justify-center p-2 text-teal-800 dark:text-white transition-colors duration-1000">
                            <span class="flex justify-between items-center">
                                <span class="native-company text-gray-500 dark:text-teal-500 text-xs mb-1 transition-colors duration-1000">Sponsored by ##company##</span>
                                <span class="native-cta text-xs sm:text-sm rounded-full flex sm:hidden justify-center flex-shrink-0 w-max h-full ml-2 sm:ml-0 mb-1 py-1 px-4" style="color: ##ctaTextColor##; background-color: ##ctaBackgroundColor##">##callToAction##</span>
                            </span>
                            <span class="native-desc text-xs sm:text-sm">##description##</span>
                            </div>
                            <span class="native-cta text-xs sm:text-sm rounded-full hidden sm:flex justify-center w-max ml-2 sm:ml-0 mb-1 py-1 px-4" style="color: ##ctaTextColor##; background-color: ##ctaBackgroundColor##">##callToAction##</span>
                        </span>
                        </a>
                    </div>
                    `,
            });
        }
    })();
</script>
