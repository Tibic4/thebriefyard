<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=UA-131354364-1"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "UA-131354364-1");
    </script>

    <!-- Plausible Analytics -->
    <script
      defer
      data-domain="goodbrief.io"
      src="https://plausible.io/js/script.tagged-events.js"
    ></script>

    <!-- Meta -->
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>
      Get Unique Design Briefs - Creative Brief Generator | Good Brief
    </title>
    <meta name="title" content="Goodbrief: Get Unique Design Briefs" />
    <meta
      name="description"
      content="Randomly generate smart design briefs to
    practice your design skills, get content for your portfolio
    and gain experience working off a real design brief."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://goodbrief.io/" />
    <meta property="og:title" content="Goodbrief: Get Unique Design Briefs" />
    <meta
      property="og:description"
      content="Randomly generate design briefs to practice your design skills, get content for your portfolio and gain experience."
    />
    <meta property="og:image" content="https://goodbrief.io/social.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://goodbrief.io/" />
    <meta
      property="twitter:title"
      content="Goodbrief: Get Unique Design Briefs"
    />
    <meta
      property="twitter:description"
      content="Randomly generate design briefs to practice your design skills, get content for your portfolio and gain experience."
    />
    <meta property="twitter:image" content="https://goodbrief.io/social.png" />

    <!-- Favicons -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png?v=3"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicons/favicon-32x32.png?v=3"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicons/favicon-16x16.png?v=3"
    />
    <link rel="manifest" href="/favicons/site.webmanifest?v=3" />
    <link rel="shortcut icon" href="/favicons/favicon.ico?v=3" />
    <meta name="apple-mobile-web-app-title" content="Goodbrief" />
    <meta name="application-name" content="Goodbrief" />
    <meta name="msapplication-TileColor" content="#086054" />
    <meta
      name="msapplication-config"
      content="/favicons/browserconfig.xml?v=3"
    />

    <meta name="theme-color" content="#0F9587" />

    <link rel="manifest" href="manifest.json" />

    <!-- Dark Mode -->
    <script>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.querySelector("html").classList.add("dark");
      } else {
        document.querySelector("html").classList.remove("dark");
      }
    </script>

    <style>
      body {
        background: #00bfa5;
        visibility: hidden;
      }

      .dark body {
        background: black;
      }
    </style>

    <!-- CSS -->
    <link
      rel="preload"
      href="/main.min.css"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="/main.min.css" />
    </noscript>
  </head>

  <body
    class="preload bg-teal-500 dark:bg-black min-h-screen overflow-auto transition-colors duration-1000 visible"
  >
    <header
      class="flex items-center sm:items-baseline m-4 sm:mt-[1.15em] sm:mb-7 sm:mx-0 sm:px-4"
    >
      <a href="/" class="flex items-center sm:items-baseline mr-4">
        <img src="/assets/logo32.png" class="mr-3 h-8 self-center" />
        <h1 class="sm:inline-block text-white hidden sm:text-2xl">Goodbrief</h1>
      </a>
      <nav class="flex ml-auto text-white items-center">
        
        <a
          href="https://goodpalette.io"
          class="flex relative rounded-full items-center py-1 mr-2 transition-colors duration-1000"
        >
          <img
            src="https://goodpalette.io/favicon-32x32.png"
            class="h-5 md:h-4 sm:mr-1"
          />
          <p class="text-teal-50 dark:text-white hidden md:inline-block">
            Goodpalette
          </p>
        </a>
        <div class="mr-2 text-teal-400 dark:text-teal-800 transition-colors duration-1000">|</div>
        <a
          href="/newsletter"
          class="flex relative rounded-full items-center bg-teal-600 dark:bg-teal-800 py-1 px-3 mr-4 transition-colors duration-1000 plausible-event-name=Merch+Header"
        >
          <ion-icon name="mail" size="small" class="mr-1 -rotate-6 text-teal-200"></ion-icon>
          <p class="text-teal-50 dark:text-white md:inline-block">
            Newsletter
          </p>
          <p
            class="bg-yellow-400 text-yellow-900 rounded-full text-[0.65em] font-black px-1 pt-[1px] -pb-[2px] absolute -top-2 -right-4 sm:-top-2 sm:-right-3"
          >
            NEW!
          </p>
        </a>
        <p><a href="/about">About</a></p>
        <button
          class="leading-0 ml-4 rounded-full p-1.5 bg-teal-400 dark:bg-dark-teal transition-colors duration-1000"
          type="button"
          onclick="changeTheme()"
        >
          <ion-icon name="moon" size="small" class="dark:hidden"></ion-icon>
          <ion-icon
            name="sunny"
            size="small"
            class="hidden dark:inline-block"
          ></ion-icon>
        </button>
      </nav>
    </header>
    <div
      class="relative max-w-3xl mx-auto pb-12 sm:px-3"
    >

  <div class="flex flex-col bg-white dark:bg-teal-900 dark:text-white rounded p-4 items-center max-w-md mx-auto my-8">
    <h2 class="text-6xl font-bold text-teal-500 mb-4">404</h2>
    <p>The page you are looking for cannot be found.</p>
    <p>If you found this error in error, please <a class="text-teal-600 underline" href="/faq">let me know</a>.</p>
    <p class="mt-4">You can <a class="text-teal-600 underline" href="javascript:history.back()">go back</a>, or <a
        class="text-teal-600 underline" href="/">go to the home page</a>.</p>
  </div>

  </div>
<div class="fixed bottom-2 right-4 text-teal-900 dark:text-teal-600 transition-colors duration-1000">v3.0</div>
<script src="/js/main.min.js"></script>
</body>

</html>
<script src="https://unpkg.com/ionicons@5.4.0/dist/ionicons.js"></script>
<script type="module" src="https://unpkg.com/ionicons@5.4.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule="" src="https://unpkg.com/ionicons@5.4.0/dist/ionicons/ionicons.js"></script>


<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap" as="style"
    onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://fonts.googleapis.com/css?family=Nunito+Sans:400,700,800&display=swap" as="style"
    onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" as="style"
    onload="this.onload=null;this.rel='stylesheet'">
<noscript>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Nunito+Sans:400,700,800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
</noscript>
<script>
    if (window.innerWidth <= 640) {
        document.querySelector(".native-carbon").remove();
        document
            .querySelector(".native-carbon-mobile")
            .classList.add("native-carbon");
        document
            .querySelector(".native-carbon-mobile")
            .classList.remove("native-carbon-mobile");
    }
</script>
<script src="//m.servedby-buysellads.com/monetization.custom.js" type="text/javascript"></script>
<script>
    (function () {
        if (typeof _bsa !== 'undefined' && _bsa) {
            _bsa.init('custom', 'CESIPKJJ', 'placement:SITENAME', {
                target: '.native-carbon',
                template: `
                <div class="native-container relative border-gray-200 border-2 sm:border-none dark:border-teal-900 bg-white dark:bg-teal-900 rounded sm:p-2 mb-3 transition-colors duration-1000">
                    <a href="##link##" class="native-banner flex sm:flex-col">
                        <div class="flex items-center justify-center p-2 min-w-1/3 sm:min-w-0" style="background: ##backgroundColor##">
                          <img class="native-img max-h-10" src="##logo##" style="background: ##backgroundColor##">
                        </div>
                        <span>
                            <div class="native-details flex flex-col justify-center p-2 text-teal-800 dark:text-white transition-colors duration-1000">
                            <span class="flex justify-between items-center">
                                <span class="native-company text-gray-500 dark:text-teal-500 text-xs mb-1 transition-colors duration-1000">Sponsored by ##company##</span>
                                <span class="native-cta text-xs sm:text-sm rounded-full flex sm:hidden justify-center flex-shrink-0 w-max h-full ml-2 sm:ml-0 mb-1 py-1 px-4" style="color: ##ctaTextColor##; background-color: ##ctaBackgroundColor##">##callToAction##</span>
                            </span>
                            <span class="native-desc text-xs sm:text-sm">##description##</span>
                            </div>
                            <span class="native-cta text-xs sm:text-sm rounded-full hidden sm:flex justify-center w-max ml-2 sm:ml-0 mb-1 py-1 px-4" style="color: ##ctaTextColor##; background-color: ##ctaBackgroundColor##">##callToAction##</span>
                        </span>
                        </a>
                    </div>
                    `,
            });
        }
    })();
</script>