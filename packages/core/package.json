    "test:watch": "vitest"
  },
  "devDependencies": {
    "@briefyard/eslint-config": "workspace:*",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "@briefyard/content": "workspace:^",
    "@briefyard/types": "workspace:*",
    "zod": "^3.23.8"
  }
}
