{
  "name": "@briefyard/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly",
    "lint": "eslint . --ext .ts --max-warnings=0",
